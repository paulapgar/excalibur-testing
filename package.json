{
  "name": "template-ts-vite",
  "version": "1.2.0",
  "description": "Excalibur TypeScript template for Vite",
  "main": "src/main.ts",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "tsc && vite build",
    "serve": "vite preview",
    "test": "npm run build && npx playwright test",
    "test:integration-update": "npx playwright test --update-snapshots",
    "lint": "node -r jiti ./node_modules/eslint/bin/eslint.js \"src/**/*.{ts,tsx,js,jsx}\"",
    "lint:fix": "node -r jiti ./node_modules/eslint/bin/eslint.js --fix \"src/**/*.{ts,tsx,js,jsx}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/excaliburjs/template-ts-vite.git"
  },
  "keywords": [
    "excalibur",
    "excaliburjs",
    "vite",
    "game-engine"
  ],
  "author": "Erik Onarheim",
  "license": "BSD-2-Clause",
  "bugs": {
    "url": "https://github.com/excaliburjs/template-ts-vite/issues"
  },
  "homepage": "https://github.com/excaliburjs/template-ts-vite#readme",
  "dependencies": {
    "@excaliburjs/plugin-aseprite": "^0.32.1",
    "excalibur": "0.32.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "typescript": "5.9.3",
    "vite": "6.4.1"
  }
}
